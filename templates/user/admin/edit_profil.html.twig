{% extends 'base.html.twig' %}

{% block title %}Profil de {{ user.name|default(user.email) }}{% endblock %}

{% block body %}

    <a class="btn-retour" href="{{ url('user.index') }}">RETOUR</a>

    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">

                <div class="card shadow-lg border-0">
                    <div class="card-body p-5">
                        {{ form_start(form, {'method': 'POST','attr': {'data-turbo': 'false'}}) }}

                        {# En-tête avec image de profil #}
                        <div class="text-center mb-4">
                            {% if user.image is not null %}
                                <img src="data:{{ user.imageMime|default('image/jpeg') }};base64,{{ image|base64_encode }}"
                                     id="image-preview"
                                     alt="Photo de {{ user.name }}"
                                     class="rounded-circle border border-3 border-white shadow-sm"
                                     style="width: 180px; height: 180px; object-fit: cover; margin: 0 auto;">
                            {% else %}
                                <div class="rounded-circle bg-light d-flex align-items-center justify-content-center mx-auto shadow-sm"
                                     style="width: 180px; height: 180px; font-size: 4rem;">
                                    👤
                                </div>
                            {% endif %}
                            {{  form_row (form.image) }}
                        </div>

                        {# Nom et email #}
                        <h1 class="text-center mb-1">{{  form_row (form.name) }}</h1>
                        <p class="text-center text-muted mb-4">{{  form_row (form.email) }}</p>

                        <hr class="my-4">

                        <div class="row g-4">

                            {# Informations générales #}
                            <div class="col-md-6">
                                <h5 class="text-primary mb-3">
                                    <i class="fas fa-user"></i> Informations
                                </h5>
                                <ul class="list-unstyled">
                                        <li class="mb-3">
                                            {{ form_row (form.bornAt) }}
                                        </li>
                                        <li>
                                            {{  form_row (form.country) }}
                                        </li>
                                        <li>
                                            {{  form_row (form.city) }}
                                        </li>
                                </ul>
                            </div>

                            {# Résumé / Bio #}
                            <div class="col-md-6">
                                <h5 class="text-primary mb-3">
                                    <i class="fas fa-info-circle"></i> À propos
                                </h5>
                                {{  form_row (form.about) }}
                            </div>
                        </div>

                        <div class="user-form-edit-submit">
                            {{  form_row (form.save) }}
                        </div>
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const imageInput = document.getElementById('{{ form.image.vars.id }}');

            if (imageInput) {
                imageInput.addEventListener('change', function(e) {
                    const file = e.target.files[0];

                    if (file) {
                        let previewImg = document.getElementById('image-preview');
                        // Vérification que c'est bien une image
                        if (!file.type.startsWith('image/')) {
                            alert("Veuillez sélectionner une image valide");
                            return;
                        }

                        const reader = new FileReader();

                        reader.onload = function(event) {
                            previewImg.src = event.target.result;
                            previewImg.style.display = 'block';
                        };

                        reader.readAsDataURL(file);
                    }
                });
            }
        });
    </script>
{% endblock %}
