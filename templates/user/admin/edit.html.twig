{% extends 'base.html.twig' %}

{% block title %} {{ title }} {% endblock %}

{% block body %}
    <a class="btn-retour" href="{{ url('user.index') }}">RETOUR</a>
    <br/>

    <div class="user-form-edit-title-ctn">
        <h1 class="user-form-edit-title">Modification UtilisateurID: {{user.id}}</h1>
    </div>

    {{ form_start(form, {'method': 'POST','attr': {'data-turbo': 'false'}}) }}


        <div class="user-edit-grid-3x3">
            {{  form_row (form.name) }}
            {{  form_row (form.email) }}
            {{  form_row (form.bornAt) }}
            {{  form_row (form.country) }}
            {{  form_row (form.city) }}
            {{  form_row (form.image) }}

            {# Zone de prévisualisation #}
            <div class="image-preview-container mt-3">
                <p><strong>Prévisualisation :</strong></p>
                <img id="image-preview"
                     src="{% if user.image is not null %}data:{{ user.imageMime|default('image/jpeg') }};base64,{{ user.image|base64_encode }}{% endif %}"
                     alt="Prévisualisation"
                     class="img-fluid"
                     style="max-height: 300px; display: {% if user.image is null %}none{% else %}block{% endif %};">
            </div>
        </div>

        <div class="user-form-edit-b2">
            {{  form_row (form.about) }}
        </div>

        <div class="user-form-edit-submit">
            {{  form_row (form.save) }}
        </div>

    {{ form_end(form) }}

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const imageInput = document.getElementById('{{ form.image.vars.id }}');

            if (imageInput) {
                imageInput.addEventListener('change', function(e) {
                    const file = e.target.files[0];

                    if (file) {
                        let previewImg = document.getElementById('image-preview');
                        // Vérification que c'est bien une image
                        if (!file.type.startsWith('image/')) {
                            alert("Veuillez sélectionner une image valide");
                            return;
                        }

                        const reader = new FileReader();

                        reader.onload = function(event) {
                            previewImg.src = event.target.result;
                            previewImg.style.display = 'block';
                        };

                        reader.readAsDataURL(file);
                    }
                });
            }
        });
    </script>
{% endblock %}
