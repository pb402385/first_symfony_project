{# templates/construction.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Page en construction{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .construction {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }
        .construction-card {
            text-align: center;
            max-width: 600px;
            padding: 3rem 2rem;
        }
        .icon-construction {
            font-size: 6rem;
            margin-bottom: 1.5rem;
            animation: pulse 2s infinite;
        }
        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.08); }
        }
    </style>
{% endblock %}

{% block body %}
    <div class="construction">
        <div class="construction-card">
            <div class="icon-construction">🚧</div>

            <h1 class="display-4 fw-bold mb-4">Page en construction</h1>

            <p class="lead mb-5">
                Nous travaillons actuellement sur cette page.<br>
                Elle sera disponible très bientôt !
            </p>

            <div class="progress mb-4" style="height: 8px;">
                <div class="progress-bar progress-bar-striped progress-bar-animated bg-warning"
                     role="progressbar"
                     style="width: 65%"></div>
            </div>

            <p class="mb-5 text-white-50">
                Merci pour votre patience ❤️
            </p>

            {% if app.user %}
                <a href="{{ path('home.index') }}" class="btn btn-light btn-lg">
                    <i class="fas fa-home"></i> Retour à l'accueil
                </a>
            {% else %}
                <a href="{{ path('home.index') }}" class="btn btn-light btn-lg">
                    <i class="fas fa-home"></i> Retour à l'accueil
                </a>
            {% endif %}
        </div>
    </div>
{% endblock %}
