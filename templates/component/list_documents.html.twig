<div class="container mt-5">
    <div class="d-flex justify-content-center align-items-center mb-4">
        <h1 class="h2 mb-0">
            <i class="fas fa-clock text-primary"></i>  Documents créés par {{ user.email }}
        </h1>
    </div>

    <div class="d-flex justify-content-center align-items-center row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        {% for document in documents %}
            <div class="col">
                <div class="card h-100 shadow-sm hover-shadow transition">

                    {# Miniature / Icône #}
                    <div class="card-img-top bg-light d-flex align-items-center justify-content-center"
                         style="height: 160px;">
                        {% set ext = document.file|split('.')|last|lower|default('') %}
                        {% if ext in ['jpg', 'jpeg', 'png', 'gif', 'webp'] %}
                            <img src="{{ asset('uploads/documents/' ~ document.file) }}"
                                 class="img-fluid h-100 w-100"
                                 style="object-fit: cover;"
                                 alt="{{ document.title }}">
                        {% elseif ext == 'pdf' %}
                            <i class="fas fa-file-pdf fa-5x text-danger"></i>
                        {% else %}
                            <i class="fas fa-file fa-5x text-secondary"></i>
                        {% endif %}
                    </div>

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title line-clamp-2">{{ document.title }}</h5>

                        <div class="mt-auto">
                            {% if document.category %}
                                <span class="badge bg-primary-subtle text-primary mb-2">
                                    {{ document.category.label }}
                                </span>
                            {% endif %}

                            <small class="text-muted d-block">
                                Ajouté le {{ document.createdAt|date("d/m/Y") }}
                            </small>
                        </div>
                    </div>

                    <div class="card-footer bg-white border-0">
                        <a href="{{ path('document.show', {id:document.id}) }}"
                           class="btn btn-sm btn-outline-primary w-100">
                            Voir le document
                        </a>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12">
                <div class="alert alert-info text-center">
                    Aucun document disponible pour le moment.
                </div>
            </div>
        {% endfor %}
    </div>
</div>


