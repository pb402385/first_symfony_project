{% extends 'base.html.twig' %}

{% block title %}Noter le document{% endblock %}

{% block body %}
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">

                <a href="{{ path('document.show', {id: document.id}) }}" class="btn btn-outline-secondary mb-4">
                    ← Retour au document
                </a>

                <div class="card shadow">
                    <div class="card-header bg-white">
                        <h4 class="mb-0">Noter : {{ document.title }}</h4>
                    </div>

                    <div class="card-body">
                        {{ form_start(form, {'method': 'POST','attr': {'data-turbo': 'false'}}) }}

                        {# Note en étoiles #}
                        <div class="mb-4">
                            {{ form_label(form.rating, 'Votre note') }}
                            <div class="star-rating">
                                {{ form_widget(form.rating) }}
                            </div>
                            {{ form_errors(form.rating) }}
                        </div>

                        {# Commentaire #}
                        <div class="mb-4">
                            {{ form_label(form.comment, 'Commentaire (optionnel)') }}
                            {{ form_widget(form.comment, {
                                'attr': {
                                    'rows': 5,
                                    'placeholder': 'Que pensez-vous de ce document ?'
                                }
                            }) }}
                            {{ form_errors(form.comment) }}
                        </div>

                        <div class="d-grid">
                            {{ form_widget(form.save, {
                                'attr': {
                                    'class': 'btn btn-primary btn-lg'
                                }
                            }) }}
                        </div>

                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block stylesheets %}
    <style>
        .star-rating {
            font-size: 2.2rem;
        }
        .star-rating label {
            cursor: pointer;
            color: #ddd;
            transition: color 0.2s;
        }
        .star-rating input:checked ~ label,
        .star-rating label:hover,
        .star-rating label:hover ~ label {
            color: #ffc107;
        }
    </style>
{% endblock %}
