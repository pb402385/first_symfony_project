{% extends 'base.html.twig' %}

{% block title %}Avis sur {{ document.title }}{% endblock %}

{% block body %}
    <div class="container mt-5">
        <div class="row justify-content-center">
            <a class="btn-retour" href="{{ url('document.index') }}">RETOUR</a>
            <div class="card shadow-lg border-0">

                <h1 class="text-primary mb-3 mt-3" style="font-weight: bold; text-align: center">Avis sur "{{ document.title }}"</h1>

                {# Note moyenne #}
                {% if averageRating is defined and totalNotes > 0 %}
                    <div class="mb-5 p-4 bg-light rounded note-all-container">
                        <div class="d-flex align-items-center gap-3">
                            <h2 class="display-4 mb-0 text-primary">{{ averageRating|number_format(1) }}</h2>
                            <div>
                                <div class="fs-3">/ 5</div>
                                <small class="text-muted">{{ totalNotes }} avis</small>
                            </div>
                        </div>
                    </div>
                {% endif %}

                    <div class="bloc-all-avis">
                        {% if notes is empty %}
                            <div class="alert alert-info text-center py-5">
                                <i class="fas fa-comment-dots fa-3x mb-3 text-muted"></i>
                                <p class="mb-0">Aucun avis n'a encore été laissé sur ce document.</p>
                            </div>
                        {% else %}
                            {% for note in notes %}
                                <div class="card mb-4 shadow-sm">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <strong>{{ note.user.name|default(note.user.email) }}</strong>
                                            </div>
                                            <small class="text-muted">
                                                {{ note.createdAt|date('d/m/Y à H:i') }}
                                            </small>
                                        </div>

                                        {# Affichage des étoiles #}
                                        <div class="my-3">
                                            {% for i in 1..5 %}
                                                {% if i <= note.rating %}
                                                    <span class="text-warning">★</span>
                                                {% else %}
                                                    <span class="text-muted">★</span>
                                                {% endif %}
                                            {% endfor %}
                                            <span class="ms-2 text-muted">({{ note.rating }}/5)</span>
                                        </div>

                                        {% if note.comment %}
                                            <p class="mb-0">{{ note.comment|nl2br }}</p>
                                        {% else %}
                                            <p class="text-muted fst-italic">Aucun commentaire</p>
                                        {% endif %}
                                    </div>
                                </div>
                            {% endfor %}
                        {% endif %}
                    </div>
            </div>
        </div>
    </div>
{% endblock %}
