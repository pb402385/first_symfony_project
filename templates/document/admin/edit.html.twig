{% extends 'base.html.twig' %}

{% block title %} {{ title }} {% endblock %}

{% block body %}
    <a class="btn-retour" href="{{ url('document.index') }}">RETOUR</a>
    <br/>

    <div class="user-form-edit-title-ctn">
        <h1 class="user-form-edit-title">Modification DocumentID: {{document.id}}</h1>
    </div>

    {{ form_start(form, {'attr': {'data-turbo': 'false'}}) }}


        <div class="document-add-grid-3x1">
            {{  form_row (form.title) }}
            {{  form_row (form.file) }}

            <div class="document-form-edit-category-bloc">
                <label for="category_select" class="form-label">Catégorie:</label>
                <select name="category_select">
                    {% for category in categories %}
                        {% if category.id == categoryId %}
                            <option value="{{ category.id }}" selected>{{ category.label }}</option>
                        {% else %}
                            <option value="{{ category.id }}" >{{ category.label }}</option>
                        {% endif %}
                    {% endfor %}
                </select>
            </div>
        </div>

        <div class="document-form-add-long-text">
            {{  form_row (form.abstract) }}
        </div>

        <div class="user-form-edit-submit">
            {{  form_row (form.save) }}
        </div>

    {{ form_end(form) }}

{% endblock %}
