{% extends 'base.html.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block body %}
    <a class="btn-retour" href="{{ url('home.index') }}">RETOUR</a>
    <br/>

    <div class="category-index-title-ctn">
        <h1 class="category-index-title">Liste de toutes les categories:</h1>
    </div>

    {% if is_granted('ROLE_ADMIN') %}
        <div class="btn btn-primary btn-sm category-index-list-table">
            <a class="category-index-add-a" href="{{ path('admin.category.add') }}">Créer une categorie</a>
        </div>
    {% endif %}

    <div class="category-list-container">
        <table class="table category-index-list-table">
            <thead>
            <tr>
                <th>Catérorie label</th>
                {% if is_granted('ROLE_ADMIN') %}
                    <th>Action</th>
                {% endif %}
            </tr>
            </thead>

            {% for category in categories %}
                <tr>
                    <td>
                        <a class="category-index-list-a text-indigo-600">{{ loop.index }} : {{ category.label }}</a>
                    </td>
                    {% if is_granted('ROLE_ADMIN') %}
                        <td class="category-index-actions-td">
                            <form action="{{ path('admin.category.delete', {id:category.id}) }}" method="post">
                                <input type="hidden" name="_method" value="DELETE">
                                <button type="submit" class="btn btn-danger btn-sm">Supprimer</button>
                            </form>
                        </td>
                    {% endif %}
                </tr>
            {% endfor %}
        </table>
    </div>

{% endblock %}
