{% extends 'base.html.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block body %}
    <a class="btn-retour" href="{{ url('home.index') }}">RETOUR</a>
    <br/>

    <div class="user-form-add-title-ctn">
        <h1 class="user-form-add-title">Liste de tous les documents:</h1>
    </div>

    {% if user is not null %}
        <p>Bonjour, {{ user.email }} !</p>
        <p>Bonjour, {{ app.user.email }} !</p>
        {% if is_granted('ROLE_ADMIN') %}
            votre utilisateur est de type ADMIN
        {% endif %}
        {% if is_granted('ROLE_USER') %}
            votre utilisateur est de type USER
        {% endif %}
    {% else %}
        <p>Uilisateur non authentifié!</p>
        <p>Veuillez vous connecter.</p>
    {% endif %}

    <button class="btn btn-secondary btn-sm" id="test-api-btn">
        TEST API/ME
    </button>

    <div class="btn btn-primary btn-sm user-index-list-table">
        <a class="user-index-add-a" href="{{ path('document.add.to.fs') }}">Créer un document</a>
    </div>

    <table class="table">
        <thead>
            <tr>
                {% if is_granted('ROLE_ADMIN') %}
                    <th>{{ knp_pagination_sortable(documents, 'ID', 'd.id') }}</th>
                {% endif %}
                <th>{{ knp_pagination_sortable(documents, 'Titre', 'd.title') }}</th>
                <th>{{ knp_pagination_sortable(documents, 'Categorie', 'd.categoryId') }}</th>
                <th>{{ knp_pagination_sortable(documents, 'Date Création', 'd.createdAt') }}</th>
                <th>{{ knp_pagination_sortable(documents, 'Date modification', 'd.updatedAt') }}</th>
                <th>Action</th>
            </tr>
        </thead>

        {% for document in documents %}
        <tr>
            {% if is_granted('ROLE_ADMIN') %}
                <td>
                    <a class="user-index-list-a text-indigo-600" href="{{ path('document.show', {id:document.id}) }}"> {{ document.id }}</a>
                </td>
            {% endif %}
            <td>
                <a class="user-index-list-a text-indigo-600" href="{{ path('document.show', {id:document.id}) }}">{{ document.title }}</a>
            </td>
            <td>
                <a class="user-index-list-a text-indigo-600" href="{{ path('document.show', {id:document.id}) }}">{{ document.categoryId }}</a>
            </td>
            <td>
                <a class="user-index-list-a text-indigo-600" href="{{ path('document.show', {id:document.id}) }}">{{ document.createdAt|date("d/m/Y")  }}</a>
            </td>
            <td>
                <a class="user-index-list-a text-indigo-600" href="{{ path('document.show', {id:document.id}) }}">{{ document.updatedAt|date("d/m/Y")  }}</a>
            </td>
            <td class="user-index-actions-td">
                <a class="user-index-list-a text-indigo-600" href="{{ path('document.show', {id:document.id}) }}">Voir</a>

                {% if is_granted('ROLE_ADMIN') or document.userId == user.id  %}
                    <a class="user-index-list-a text-indigo-600" href="{{ path('document.edit', {id:document.id}) }}">Editer</a>
                    <form action="{{ path('document.delete', {id:document.id}) }}" method="post">
                        <input type="hidden" name="_method" value="DELETE">
                        <button type="submit" class="btn btn-danger btn-sm">Supprimer</button>
                    </form>
                {% endif %}

            </td>
        </tr>
        {% endfor %}
        {% if documents == null %}
        <tr>
            <td>
                <p><strong>Il n'y a aucun document!</strong></p>
            </td>
            <td></td>
        </tr>
        {% endif %}
    </table>

    <div class="pagination_container">
        {{ knp_pagination_render(documents) }}
    </div>


    {% block javascripts %}
        {{ parent() }}   {# ← Très important #}
        <script>
            document.getElementById('test-api-btn')?.addEventListener('click', async () => {
                const token = localStorage.getItem('jwt_token'); // ou le nom que tu utilises

                try {
                    const response = await fetch('{{ url('api_me') }}', {
                        method: 'GET',
                        headers: {
                            'Authorization': `Bearer ${token}`,
                            'Accept': 'application/json',
                        }
                    });

                    if (!response.ok) {
                        alert("Erreur, il faut être authentifié pour accéder à l'API response status:"+response?.status);
                        console.error("Erreur, il faut être authentifié pour accéder à l'API response:", response);
                        return;
                    }

                    const data = await response.json();

                    if(response.ok){
                        alert("Email: "+data?.user?.email+"\n" +"Rôle: "+data?.user?.roles+"\n");
                    }
                } catch (error) {
                    console.error('Erreur réseau:', error);
                    alert("Erreur réseau ou autre: erreur->"+error);
                }
            });
        </script>
    {% endblock %}


{% endblock %}
