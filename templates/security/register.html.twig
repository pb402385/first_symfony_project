{% extends 'base.html.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block body %}

    <div class="register-body">
        <div class="register-box">

            <a class="btn-retour" href="{{ path('home.index') }}">RETOUR</a>
            <br/>
            <h2>Créer un compte</h2>

            <form id="registerForm">
                <input class="register" type="email" id="email" placeholder="Email" required>
                <input class="register" type="password" id="password" placeholder="Mot de passe" required>
                <input class="register" type="password" id="password_confirm" placeholder="Confirmer le mot de passe" required>

                <button class="register" type="submit">S'inscrire</button>
            </form>

            <p id="message"></p>

            <p style="text-align: center; margin-top: 20px;">
                Déjà un compte ? <a href="{{ path('app_login') }}">Se connecter</a>
            </p>
        </div>
    </div>

    <script>
        document.getElementById('registerForm').addEventListener('submit', async (e) => {
            e.preventDefault();

            const messageDiv = document.getElementById('message');
            messageDiv.textContent = '';

            const formData = {
                email: document.getElementById('email').value,
                password: document.getElementById('password').value,
                password_confirm: document.getElementById('password_confirm').value
            };

            try {
                const response = await fetch('/api/register', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(formData)
                });

                const data = await response.json();

                if (response.ok) {
                    messageDiv.className = 'register-success';
                    messageDiv.textContent = 'Compte créé avec succès ! Redirection...';

                    // Sauvegarde du token
                    localStorage.setItem('jwt_token', data.token);

                    let email = data.user.email;
                    let url = "{{ path('home.new-user') }}" +"?email="+email;

                    setTimeout(() => {
                        window.location.href = url;
                    }, 2000);
                } else {
                    messageDiv.className = 'register-error';
                    messageDiv.textContent = data.message || 'Erreur lors de l\'inscription';
                }
            } catch (err) {
                messageDiv.className = 'error';
                messageDiv.textContent = 'Erreur de connexion au serveur';
            }
        });
    </script>

{% endblock %}
