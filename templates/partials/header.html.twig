<nav class="bg-white shadow-md sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
        <div class="flex items-center space-x-3">
            <a href="{{ url('home.index') }}">
                <i class="fa-solid fa-book-open text-3xl text-indigo-600"></i>
                <span class="text-2xl font-bold text-gray-800">DocShare</span>
            </a>
        </div>

        {% if is_granted('IS_AUTHENTICATED_FULLY') %}
        <div class="hidden md:flex items-center space-x-8">
            <a href="{{ url('document.index') }}" class="text-gray-700 hover:text-indigo-600 font-medium {{ app.current_route starts with 'document' ? 'a-nav-active' : ''}}">Documents</a>
            <a href="{{ url('user.index') }}" class="text-gray-700 hover:text-indigo-600 font-medium {{ app.current_route == 'user.index' ? 'a-nav-active' : ''}}">Utilisateurs</a>
        </div>
        {% endif %}

        <div class="flex items-center gap-4" id="nav-auth">

            {% if is_granted('IS_AUTHENTICATED_FULLY') %}
                <a href="{{ path('user.show', {id:app.user.id}) }}" id="profil-link" class="btn btn-outline-primary px-4 ms-3">
                    <i class="fa-solid fa-user"></i> Mon Profil
                </a>

                <a href="#" onclick="revokeTokenAndDisconnect()" id="logout-link" class="btn btn-outline-danger px-4 ms-3">
                    <i class="fas fa-sign-out-alt"></i> Déconnexion
                </a>

                {% block javascripts %}
                    <script>
                        // On force l'envoit du JWT token lors de la déconnexion
                        function revokeTokenAndDisconnect() {
                            const token = localStorage.getItem('jwt_token'); // ou le nom que tu utilises
                            if (token) {
                                // Ajoute le token dans le header de la requête de déconnexion
                                fetch(window.location.origin + '/revokeToken', {
                                    method: 'POST',
                                    headers: {
                                        'Authorization': `Bearer ${token}`
                                    }
                                }).then(() => {
                                    // Redirection manuelle après envoi
                                    localStorage.removeItem('jwt_token');
                                    window.location.href = window.location.origin + '/logout';
                                });
                            }
                        }
                    </script>
                {% endblock %}

            {% else %}
                {% if show_disconnect is defined and show_disconnect is not null %}
                {% else %}
                    <button onclick="window.location.href='{{ path('app_login') }}'"
                            class="px-5 py-2 text-indigo-600 hover:bg-indigo-50 rounded-xl font-medium transition {{ app.current_route == 'app_login' ? 'auth-login-btn-hidden' : ''}}">
                        Connexion
                    </button>

                    <button onclick="window.location.href='{{ path('auth.register') }}'"
                            class="px-6 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl font-medium transition {{ app.current_route == 'auth.register' ? 'auth-register-btn-hidden' : ''}}">
                        Inscription gratuite
                    </button>
                {% endif %}
            {% endif %}
        </div>
    </div>
</nav>
